@model Theme
<div class="form-block">
    <h2>Тема</h2>
    <form asp-action="SaveTheme" method="post">
        <label asp-for="Name">Имя Темы:</label>
        <input type="text" id="Name" name="Name" value="@Model.Name" required><br>

        <label asp-for="Duration">Продолжительность в неделях:</label>
        <input type="number" id="Duration" name="Duration" value="@Model.Duration" min=0 oninput="validity.valid||(value='')" required><br>

        <head>
            <meta charset="utf-8">
            <title>Содержание</title>
            <script src="https://cdn.ckeditor.com/ckeditor5/41.2.0/classic/ckeditor.js"></script>
        </head>
        <body>
            <h1>Содержание</h1>
            <textarea asp-for="Content" name="Content" id="contEditor">
                @Model.Content
        </textarea>
            <script>
                ClassicEditor
                    .create(document.querySelector('#contEditor'))
                    .catch(error => {
                        console.error(error);
                    });
            </script>
        </body>
        <p><input type="submit" value="Submit"></p>
    </form>
</div>
